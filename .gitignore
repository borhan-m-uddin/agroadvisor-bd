venv/
env/
ENV/
.venv/
.env.local
.env.development
.env.test
.env.production

# ══════════════════════════════════════════════
# SECRETS — NEVER COMMIT
# ══════════════════════════════════════════════
.env
*.env
secrets.json
config_secret.py

# ══════════════════════════════════════════════
# RAW DATA — TOO LARGE FOR HUGGINGFACE
# These are source files used only during ingestion.
# The processed database (faiss_db) is what matters.
# ══════════════════════════════════════════════
data/raw_pdfs/
data/all_documents/
data/processed_text/
data/chroma_db/
data/knowledge_base/

# ══════════════════════════════════════════════
# LARGE FILES TRACKED BY GIT LFS INSTEAD
# These are NOT ignored — they go via LFS
# data/faiss_db/   ← tracked by LFS
# data/bm25_index.pkl ← tracked by LFS
# ══════════════════════════════════════════════

# ══════════════════════════════════════════════
# GENERATED OUTPUT FILES
# ══════════════════════════════════════════════
eval_results.json
response_cache.json
data/response_cache.json
*.log
logs/

